# Path to the SQLite file (relative to project root with .env, or absolute).
SQLITE_DATABASE_PATH=obuv.sqlite

# Optional: full SQLAlchemy URL instead of SQLITE_DATABASE_PATH (e.g. for CI).
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/obuv.sqlite

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080

# If set and the users table is empty, an admin user is created on startup.
ADMIN_BOOTSTRAP_PASSWORD=
# ADMIN_BOOTSTRAP_USERNAME=admin
